APP_NAME=Lucky Insight API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/lucky_insight

JWT_SECRET_KEY=change-me-to-a-random-secret-value
JWT_REFRESH_SECRET=change-me-to-a-different-random-secret-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

LOG_LEVEL=INFO
